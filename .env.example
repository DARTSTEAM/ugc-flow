# ─── Kernel.sh — Cloud Browser ────────────────────────────────────────────────
# Obtené estos valores en https://kernel.sh/dashboard

KERNEL_API_KEY=your_api_key_here
KERNEL_PROFILE_INSTAGRAM=your_instagram_profile_id
KERNEL_PROXY_ID=your_proxy_id_here
HEADFUL_PLATFORMS=instagram

# ─── Test Agent (n8n) ────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.hikethecloud.com/webhook/hike-ugc-test-agents
N8N_AUTH_VALUE=your_n8n_auth_token_here

# ─── MiniMax (sentimiento de comentarios) ─────────────────────────────────────
# En prod viene de Secret Manager (ngr_ugc_minimax_api_key), montado como env var en Cloud Run.
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-M2.7
